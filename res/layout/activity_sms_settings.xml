<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/textViewSmsTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="SMS Notifications"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/textViewSmsDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="This app can send SMS alerts when an item is low in stock."
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/textViewSmsTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/textViewSmsStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Status: Permission not granted"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/textViewSmsDescription"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/buttonRequestSmsPermission"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Enable SMS Notifications"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/textViewSmsStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/textViewSmsInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="If you deny SMS permission, the app will still work, but it cannot send low-inventory alerts."
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/buttonRequestSmsPermission"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
